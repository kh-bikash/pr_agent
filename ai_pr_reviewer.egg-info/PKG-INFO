    │   ├── App.jsx        # Main React Dashboard Component
    │   ├── App.css        # Glassmorphism Styling
    │   └── main.jsx       # React Entry Point
    ├── package.json       # Node dependencies
    └── vite.config.js     # Vite configuration & proxy
```

